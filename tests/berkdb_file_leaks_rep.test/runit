#!/usr/bin/env bash
bash -n "$0" | exit 1

# This test demonstrates a case where ufid_hash would hold an open
# DB handle to an outdated btree file, after schema change, hence prevent
# the file from being deleted.
#
# 1. send flush
# 2. write to table
# 3. bounce a replicant
#   3.1. replicant will start matching from the LSN in step 1
#   3.2. replicant will run recovery to apply transaction from step 2
#   3.3. ufid-hash will need to open a DB handle on the btree file
# 4. truncate table, this creates new btree file
# 5. delfiles now will create "deleted" file on this replicant;
#    alternatively, if we upgrade master to this replicant and then run delfiles,
#    we'll get "DB_FILEOPEN: Rename or remove while file is open"
#
# Usage (manual): ./runit <dbname>

if [ -n "$TESTSROOTDIR" ]; then
    source ${TESTSROOTDIR}/tools/cluster_utils.sh
    [ -z "${CLUSTER}" ] && { echo "Test requires a cluster"; exit 0; }
fi

dbnm=$1

SQL="cdb2sql $dbnm local"
SQL_TABS="cdb2sql --tabs $dbnm local"

master=$($SQL_TABS "select host from comdb2_cluster where is_master='Y'")
replicant=$($SQL_TABS "select host from comdb2_cluster where is_master='N' limit 1")
the_other_replicant=$($SQL_TABS "SELECT host FROM comdb2_cluster WHERE host <> '$master' AND host <> '$replicant' limit 1")

echo "Master: $master  Replicant: $replicant  Other: $the_other_replicant"

$SQL "DROP TABLE IF EXISTS t1"
$SQL "CREATE TABLE t1 (i integer, b blob)"
sleep 2 # wait for the checkpoint thread to do its 1st checkpoint
cdb2sql $dbnm --host $master "EXEC PROCEDURE sys.cmd.send('bdb checkpoint')"
sleep 2 # wait for the async checkpoint to finish

$SQL "TRUNCATE TABLE t1"
cdb2sql $dbnm --host $master "EXEC PROCEDURE sys.cmd.send('bdb checkpoint')"
sleep 2 # wait for the async checkpoint to finish

$SQL "INSERT INTO t1 VALUES(1, x'CDB2BABE')"
sleep 2

echo ""
echo "Please kill and restart comdb2 on replicant: $replicant"
echo "Then press Enter to continue..."
read -r _
echo "Waiting for $replicant to come back up..."
for i in $(seq 1 60); do
    cdb2sql $dbnm --host $replicant "SELECT 1" >/dev/null 2>&1 && break
    sleep 2
done
cdb2sql $dbnm --host $replicant "SELECT 1" >/dev/null 2>&1 || { echo "$replicant did not come back"; exit 1; }
echo "$replicant is back up"

if [ -n "$the_other_replicant" ]; then
    echo ""
    echo "Please kill and restart comdb2 on: $the_other_replicant"
    echo "Then press Enter to continue..."
    read -r _
    echo "Waiting for $the_other_replicant to come back up..."
    for i in $(seq 1 60); do
        cdb2sql $dbnm --host $the_other_replicant "SELECT 1" >/dev/null 2>&1 && break
        sleep 2
    done
    cdb2sql $dbnm --host $the_other_replicant "SELECT 1" >/dev/null 2>&1 || { echo "$the_other_replicant did not come back"; exit 1; }
    echo "$the_other_replicant is back up"
fi

echo 'Before truncate ...'
cdb2sql $dbnm --host $replicant "EXEC PROCEDURE sys.cmd.send('bdb cachestatall')" | grep -A1 blobs0
cdb2sql $dbnm --host $master "TRUNCATE TABLE t1"
echo 'After truncate ...'
cdb2sql $dbnm --host $replicant "EXEC PROCEDURE sys.cmd.send('bdb cachestatall')" | grep -A1 blobs0

cdb2sql --tabs $dbnm --host $master "EXEC PROCEDURE sys.cmd.send('delfiles t1')"
sleep 2

echo ""
echo "Check for deleted files on each replicant:"
for host in $replicant $the_other_replicant; do
    [ -z "$host" ] && continue
    echo "  $host: lsof -p \$(pgrep -f $dbnm | head -1) | grep deleted"
done
echo ""
echo "If any replicant shows t1 blob files as deleted, the bug is present."
echo "Press Enter when done checking..."
read -r _

echo "Cleaning up..."
$SQL "DROP TABLE IF EXISTS t1"
echo "Done."
exit 0
